# Supabase（本番推奨 - 認証・データベース）
# https://supabase.com → プロジェクト作成 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase PostgreSQL（本番推奨 - Prisma用）
# https://supabase.com → Settings → Database → Connection string → URI
# Vercel/Windows環境では Transaction pooler / IPv4 compatible の接続文字列を推奨
DATABASE_URL=postgresql://postgres:[password]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Stripe（有料プラン - 任意）
# https://dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_STANDARD_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# お問い合わせメール（任意）
# https://resend.com → API Keys
RESEND_API_KEY=re_...
CONTACT_EMAIL=info@yadokari-minpaku.jp
ADMIN_EMAILS=info@yadokari-minpaku.jp

# サイトURL
NEXT_PUBLIC_SITE_URL=https://yadokari-minpaku.jp

# Google Analytics 4. Optional, e.g. G-XXXXXXXXXX.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Production property marketplace. Keep false until listings are reviewed and ready.
NEXT_PUBLIC_PROPERTY_MARKETPLACE_ENABLED=false

# デプロイ前確認
# npm run predeploy
# デプロイ後確認
# https://yadokari-minpaku.jp/api/health
